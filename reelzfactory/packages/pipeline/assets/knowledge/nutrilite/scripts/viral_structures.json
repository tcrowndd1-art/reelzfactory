    {
      "id": "pas_fear_30",
      "name": "PAS 공포형",
      "type": "PAS",
      "duration_target": 30,
      "description": "구체적 공포 증상으로 시작, 방치 결과 심화, 해결책 제시",
      "scenes": [
        {"phase": "hook", "duration_sec": 3, "render_type": "lipsync", "direction": "구체적 신체 증상을 충격적으로 언급. 예: 새벽 3시에 종아리가 찢어지는 이유"},
        {"phase": "problem", "duration_sec": 4, "render_type": "image_motion", "direction": "이 증상이 왜 생기는지 과학적 원인 1가지만 짧게"},
        {"phase": "agitate_1", "duration_sec": 3, "render_type": "image_motion", "direction": "방치하면 어떻게 되는지 악화 시나리오"},
        {"phase": "agitate_2", "duration_sec": 3, "render_type": "image_motion", "direction": "한국인 결핍률 통계로 공포 강화"},
        {"phase": "solution_1", "duration_sec": 5, "render_type": "action", "direction": "해결 성분과 작동 원리 설명"},
        {"phase": "solution_2", "duration_sec": 4, "render_type": "image_motion", "direction": "제품의 차별화 기술 강조"},
        {"phase": "proof", "duration_sec": 3, "render_type": "image_motion", "direction": "인증/연구/리뷰 근거 1가지"},
        {"phase": "solution_3", "duration_sec": 3, "render_type": "image_motion", "direction": "섭취 방법 또는 흡수 팁"},
        {"phase": "cta", "duration_sec": 2, "render_type": "lipsync", "direction": "팔로우 유도 또는 댓글 유도"}
      ],
      "effectiveness": "건강 카테고리에서 공포 기반 PAS가 가장 높은 완시청률. 첫 3초 구체적 증상이 스크롤 스톱 트리거"
    },
    {

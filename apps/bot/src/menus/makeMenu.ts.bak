// �~��f� �f��"� �<��-?
export async function executeVideoGeneration(ctx: Context, topic: string, category?: string) {
  const telegramId = ctx.from?.id;
  if (!telegramId) return;

  try {
    const user = await getOrCreateUser(telegramId);

    // �>"�" �o�.o 체크
    if (user.monthly_video_count >= user.monthly_video_limit) {
      await ctx.reply(
        `�s�️ 이�^ �<� �~��f� �o�z' �.o�"�-� �"�<��-^�S��<^�<�.\n\n` +
        `�Y"S ${user.monthly_video_count}/${user.monthly_video_limit}�o �,��s�\n` +
        `�Y'Z �"O�zo �-.그�^이�"o�o �" �Z�? �~��f��" �O�"��-�보�"��s"!`,
        Markup.inlineKeyboard([
          [Markup.button.callback('�Y'Z �"O�zo �-.그�^이�"o', 'settings_plan')],
          [Markup.button.callback('�Y"T �"인 �"�?�', 'menu_main')],
        ])
      );
      return;
    }

    // �""�o�.�.~ 기록 �f��"�
    const production = await createProduction({
      user_id: user.id,
      topic,
      category: category || 'general',
      status: 'scripting',
    });

    await trackFeature(user.id, 'make_video', { topic, category });

    const statusMsg = await ctx.reply(
      `�YZ� *�~��f� �o�z' �<o�z'!*\n\n` +
      `�Y"O 주�o: ${topic}\n` +
      `�Y", 카�.O고리: ${category || '일�~'}\n` +
      `⏱️ �~^�f� �?O�s": 3-5�"\n\n` +
      `�Y"� 1/5 �O?본 �f��"� �'...`,
      { parse_mode: 'Markdown' }
    );

    // �OO이�""라인 �<��-?
        const result = await runFullPipeline({
      topic,
      category: category || 'default',
      userId: String(ctx.from?.id || ''),
      stylePresetName: 'whiteboard',
    });


    await ctx.telegram.editMessageText(
      ctx.chat!.id, statusMsg.message_id, undefined,
      `�YZ� *�~��f� �o�z' �'*\n\n�Y"O ${topic}\n\n` +
      `�o. 1/5 �O?본 �f��"� �T"�O\n` +
      `�o. 2/5 이미�? �f��"� �T"�O\n` +
      `�o. 3/5 �O�"� �f��"� �T"�O\n` +
      `�o. 4/5 �O�"링 �T"�O\n` +
      `�Y"� 5/5 YouTube �-.�o�"o �'...`,
      { parse_mode: 'Markdown' }
    );

    // YouTube �-.�o�"o
         // AI�? �f��"��.o metadata �To�s� (�o목/�"��./�fo그 �z��T �o적�T")
    const metadata = result.metadata;
    const ytCategoryId = (await import('../../../../packages/pipeline/src/upload/uploadYoutube')).getYoutubeCategoryId(category || 'general');

    const optimizedTitle = metadata?.title || topic;
    const optimizedDescription = [
      metadata?.description || `${topic}�-� �O?�.o �~��f��z.�<^�<�.`,
      '',
      metadata?.hashtags?.join(' ') || '',
      '',
      '�Y"" 구�.과 �<�."�s" �?�f��"o려�s"!',
    ].join('\n');
    const optimizedTags = [
      ...(metadata?.tags || []),
      ...(metadata?.hashtags?.map(h => h.replace('#', '')) || []),
      topic,
    ].slice(0, 30);

    const uploadResult = await uploadToYoutube({
      videoPath: result.videoPath,
      title: optimizedTitle.substring(0, 100),
      description: optimizedDescription,
      tags: optimizedTags,
      privacyStatus: 'unlisted',
      categoryId: ytCategoryId,
    });


    if (uploadResult.success) {
      // DB �-.데이�S�
      const { updateProduction } = await import('../../../../packages/shared/supabase');
      await updateProduction(production.id, {
        status: 'review',
        youtube_video_id: uploadResult.videoId,
        youtube_url: uploadResult.videoUrl,
        video_path: result.videoPath,
      });

      await ctx.telegram.editMessageText(
        ctx.chat!.id, statusMsg.message_id, undefined,
        `�o. *�~��f� �o�z' �T"�O!*\n\n` +
        `�Y"O 주�o: ${topic}\n` +
        `�Y"- 미리보기: ${uploadResult.videoUrl}\n` +
        `�Y"' �f��fo: �"공�o(Unlisted)\n\n` +
        `�T.인 �>" 공�o �o�-?�.~�"��s" �Y'?`,
        {
          parse_mode: 'Markdown',
          ...Markup.inlineKeyboard([
            [Markup.button.url('�-�️ 미리보기', uploadResult.videoUrl!)],
            [Markup.button.callback('�o. 공�o �o�-?', `publish_now_${production.id}`)],
            [Markup.button.callback('⏰ �~^�.� �o�-?', `publish_schedule_${production.id}`)],
            [Markup.button.callback('�Y"" 리�"이크', `remake_${production.id}`)],
            [Markup.button.callback('�Y-'️ �,��o', `delete_${production.id}`)],
          ]),
        }
      );
    } else {
      await updateProduction(production.id, {
        status: 'failed',
        error_message: uploadResult.error,
      });

      await ctx.telegram.editMessageText(
        ctx.chat!.id, statusMsg.message_id, undefined,
        `�s�️ �~��f� �f��"��? �T"�O�-^�?�O �-.�o�"o �<��O�\n\n�~��~: ${uploadResult.error}`,
        {
          ...Markup.inlineKeyboard([
            [Markup.button.callback('�Y"" �<��<o �<o�"', `retry_upload_${production.id}`)],
            [Markup.button.callback('�Y"T �"인 �"�?�', 'menu_main')],
          ]),
        }
      );
    }

  } catch (error: any) {
    console.error('Video generation error:', error);
    await ctx.reply(
      `�O �~��f� �f��"� �<��O�: ${error.message}`,
      Markup.inlineKeyboard([
        [Markup.button.callback('�Y"" �<��<o �<o�"', 'menu_make')],
        [Markup.button.callback('�Y"T �"인 �"�?�', 'menu_main')],
      ])
    );
  }
}
